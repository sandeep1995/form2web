{
    on_demand_tls {
        ask http://localhost:3000/allow-host?domain={host}
        interval 2m
        burst 5
    }
}

:80 {
    redir https://{host}{uri} permanent
}

:443 {
    tls {
        on_demand
    }
    
    reverse_proxy localhost:3000 {
        header_up Host {host}
        header_up X-Forwarded-Proto https
    }
}

